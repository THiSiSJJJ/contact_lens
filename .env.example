PORT=3000
FRONTEND_BASE_URL=http://localhost:3000

# Stripe
# Use test keys first
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Google OAuth
# 1. Create an OAuth app in Google Cloud Console
# 2. Add http://localhost:3000/auth/google/callback as an authorized redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Facebook OAuth
# 1. Create an app in Meta for Developers
# 2. Add http://localhost:3000/auth/facebook/callback as a valid OAuth redirect URI
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3000/auth/facebook/callback
